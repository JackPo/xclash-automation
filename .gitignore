deprecated/

# Old discovery/calibration directories
zoom_discovery/
zoom_discovery_adb/
zoom_discovery_v2/
castle_cutouts/
level_crops/

# Windows path-mangled accident files (scripts writing literal 'C:\...' strings as filenames)
